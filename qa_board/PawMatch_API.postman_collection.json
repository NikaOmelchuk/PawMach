{
    "info": {
        "name": "PawMatch API 🐱",
        "description": "Колекція запитів для тестування API платформи PawMatch — опитування на сумісність.\n\n**Як використовувати:**\n1. Імпортуйте колекцію до Postman\n2. Імпортуйте Environment (PawMatch Environment)\n3. Запустіть запит **Login** — token збережеться автоматично\n4. Всі наступні запити будуть авторизовані автоматично",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000/api/v1",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        },
        {
            "key": "session_id",
            "value": "1",
            "type": "string"
        },
        {
            "key": "survey_id",
            "value": "1",
            "type": "string"
        },
        {
            "key": "session_code",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "🔵 Auth",
            "item": [
                {
                    "name": "App Info",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/app/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "app",
                                ""
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "pm.test('Has name field', () => {",
                                    "    const json = pm.response.json();",
                                    "    pm.expect(json).to.have.property('name');",
                                    "    pm.expect(json.name).to.include('Survey');",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"testuser_{{$timestamp}}\",\n  \"email\": \"test{{$timestamp}}@example.com\",\n  \"password\": \"securepass123\",\n  \"password2\": \"securepass123\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/register/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "register",
                                ""
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                                    "pm.test('Has token', () => {",
                                    "    const json = pm.response.json();",
                                    "    pm.expect(json).to.have.property('token');",
                                    "    pm.expect(json.token).to.be.a('string').and.not.empty;",
                                    "    pm.collectionVariables.set('token', json.token);",
                                    "});",
                                    "pm.test('Save credentials for Login', () => {",
                                    "    const reqBody = JSON.parse(pm.request.body.raw);",
                                    "    pm.collectionVariables.set('login_email', reqBody.email);",
                                    "    pm.collectionVariables.set('login_pass', reqBody.password);",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"{{login_email}}\",\n  \"password\": \"{{login_pass}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/login/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "login",
                                ""
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                                    "pm.test('Has token', () => {",
                                    "    const json = pm.response.json();",
                                    "    pm.expect(json).to.have.property('token');",
                                    "    pm.collectionVariables.set('token', json.token);",
                                    "    console.log('✅ Token saved:', json.token);",
                                    "});",
                                    "pm.test('Has user profile', () => {",
                                    "    const json = pm.response.json();",
                                    "    pm.expect(json.user).to.have.property('username');",
                                    "    pm.expect(json.user).to.have.property('email');",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Login — Wrong Password (Negative)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@admin.com\",\n  \"password\": \"WRONGPASSWORD\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/login/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "login",
                                ""
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 400 for wrong creds', () => pm.response.to.have.status(400));",
                                    "pm.test('Has error message', () => {",
                                    "    const json = pm.response.json();",
                                    "    pm.expect(json).to.have.property('non_field_errors');",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Get Profile",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Token {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/auth/profile/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "profile",
                                ""
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "pm.test('Profile fields present', () => {",
                                    "    const json = pm.response.json();",
                                    "    pm.expect(json).to.have.all.keys('id','username','email','first_name','last_name','gender','birth_date','bio','avatar','date_joined');",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Update Profile",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Token {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"first_name\": \"Мяу\",\n  \"last_name\": \"Кись\",\n  \"bio\": \"Люблю котиків і опитування 🐱\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/profile/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "profile",
                                ""
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "pm.test('Bio updated', () => {",
                                    "    const json = pm.response.json();",
                                    "    pm.expect(json.bio).to.include('котиків');",
                                    "});"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
